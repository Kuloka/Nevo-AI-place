{
  "name": "nevo-ai-place",
  "version": "1.1.6",
  "description": "Nevo - local AI coding assistant powered by Ollama",
  "main": "electron/main.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron .",
    "check": "node --check electron/main.js && node --check electron/preload.js && node --check renderer.js",
    "fix:encoding": "node scripts/fix-mojibake.js --write",
    "dist:win": "electron-builder --win portable"
  },
  "productName": "Nevo",
  "private": true,
  "build": {
    "appId": "ai.nevo.place",
    "productName": "Nevo",
    "files": [
      "**/*",
      "!dist/**",
      "!.git/**"
    ],
    "directories": {
      "buildResources": "resources",
      "output": "dist"
    },
    "win": {
      "icon": "resources/nevo-logo.ico",
      "target": [
        "portable"
      ]
    }
  },
  "devDependencies": {
    "electron": "^28.3.3",
    "electron-builder": "^26.15.3"
  }
}
